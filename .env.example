ANTHROPIC_API_KEY=your_key_here

# Filled in by scripts/setup_managed_agents.py (one-time setup).
# Required for the Managed-Agents features (iterative auditor + regulatory monitor).
# Leave blank on first run — the setup script writes them into .env for you.
MANAGED_ENV_ID=
REDTEAM_AGENT_ID=
MONITOR_AGENT_ID=

# Set to 1 to route the Red Team stage through the Managed Agent (iterative audit).
# Requires the three IDs above. Falls back to the in-process legacy flow when unset.
# MANAGED_AGENTS=1
